# ── Database ──────────────────────────────────────────────────────
# Local dev: leave DATABASE_URL unset (defaults to enoch.db)
# Production: set to Turso libsql URL
DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Session ───────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string

# ── Discord OAuth ─────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Discord Guild ─────────────────────────────────────────────────
# The NYbN server ID
DISCORD_GUILD_ID=
# Comma-separated Discord role IDs that grant staff access
STAFF_ROLE_IDS=

# ── Enoch / Inconnu sync ──────────────────────────────────────────
# The Discord guild ID used in the Inconnu bot's tables (may differ)
ENOCH_GUILD_ID=

# ── Bot service token ─────────────────────────────────────────────
# Shared secret the Discord bot uses to call /api/* endpoints
BOT_SERVICE_TOKEN=

# ── Webhooks ──────────────────────────────────────────────────────
# Discord webhook URL for IC profile change notifications (optional)
PROFILE_WEBHOOK_URL=

# ── Dev ───────────────────────────────────────────────────────────
# Set to 1 to enable /_dev/seed route (bypasses Discord OAuth)
# NEVER set this in production
ENOCH_DEV_PREVIEW=1
