# ═══════════════════════════════════════════════════════════════════════════════
# Enoch — NYbN XP Tracker — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Session ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave DATABASE_URL unset (defaults to enoch.db SQLite file)
# Production (Turso):
#   DATABASE_URL=libsql+https://your-db-name.turso.io
#   TURSO_AUTH_TOKEN=<token from `turso db tokens create your-db`>
DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Discord OAuth ─────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Discord Guild ─────────────────────────────────────────────────
# The NYbN server ID
DISCORD_GUILD_ID=
# Comma-separated Discord role IDs that grant staff access
STAFF_ROLE_IDS=

# ── Enoch / Inconnu sync ──────────────────────────────────────────
# The Discord guild ID used in the Inconnu bot's tables (may differ)
ENOCH_GUILD_ID=

# ── Bot service token ─────────────────────────────────────────────
# Shared secret the Discord bot uses to call /api/* endpoints
BOT_SERVICE_TOKEN=

# ── Discord bot token ─────────────────────────────────────────────
# Bot token from the Discord Developer Portal
DISCORD_BOT_TOKEN=

# ── Bot tuning (optional) ─────────────────────────────────────────
# How often (seconds) the bot polls the web API outbox for pending commands
# OUTBOX_POLL_INTERVAL=10

# ── Web URL (production only) ─────────────────────────────────────
# Base URL the bot uses to call the web API; defaults to localhost for dev
# WEB_URL=https://enoch.up.railway.app

# ── Webhooks ──────────────────────────────────────────────────────
# Discord webhook URL for IC profile change notifications (optional)
PROFILE_WEBHOOK_URL=

# ── Dev ───────────────────────────────────────────────────────────
# Set to 1 to enable /_dev/seed, /_dev/player, /_dev/seed_data bypass routes
# NEVER set this in production — removes all auth guards
# ENOCH_DEV_PREVIEW=1

# ── Production checklist ──────────────────────────────────────────
# Before going live:
#   [ ] SESSION_SECRET set to a real random value
#   [ ] DATABASE_URL + TURSO_AUTH_TOKEN set to Turso credentials
#   [ ] DISCORD_CLIENT_ID + SECRET configured in Discord Developer Portal
#   [ ] DISCORD_REDIRECT_URI updated to production domain + /auth/callback
#   [ ] DISCORD_GUILD_ID set to your server ID
#   [ ] STAFF_ROLE_IDS set to the role IDs for staff/storytellers
#   [ ] ENOCH_DEV_PREVIEW is NOT set (or explicitly left commented out)
#   [ ] RAILWAY_ENVIRONMENT=production is set by Railway automatically
